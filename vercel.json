{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install --legacy-peer-deps",
  "devCommand": "npm run dev",
  "headers": [
    {
      "source": "/app/:file*.apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"iarest.apk\""
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/alertas",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/cobro-inactividad",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reservas-noshow",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/cobro-descuento",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/backup/drive",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/eventos-entorno",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/blog-seo",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/prospeccion-leads",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/instagram",
      "schedule": "0 9 * * 3"
    },
    {
      "path": "/api/cron/instagram",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/instagram-ideas",
      "schedule": "30 8 * * 1"
    },
    {
      "path": "/api/cron/instagram-refresh",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/instagram-metricas",
      "schedule": "0 7 * * *"
    }
  ]
}