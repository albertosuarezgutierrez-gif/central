# ia.rest — Variables de entorno · Mayo 2026
# Copia como .env.local para desarrollo · En Vercel: Settings → Environment Variables

# ── SUPABASE ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # Solo server-side, nunca al cliente

# ── STRIPE ───────────────────────────────────────────────────
STRIPE_MODE=test                        # 'test' o 'live'
STRIPE_SECRET_KEY=sk_test_...           # Clave activa (test o live según STRIPE_MODE)
STRIPE_SECRET_KEY_TEST=sk_test_...      # Siempre test (portal dev)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET_QR=whsec_...      # Stripe → Webhooks → /api/qr/webhook
STRIPE_CLIENT_ID=ca_...                 # Stripe Connect → Settings → Client ID

# ── IA / VOZ ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_...                    # EAR: transcripción Whisper (console.groq.com)
ANTHROPIC_API_KEY=sk-ant-...            # BRAIN: interpreta comandas (console.anthropic.com)

# ── WEB PUSH ─────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BN...      # npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=...

# ── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Prod: https://www.iarest.es
APP_URL=http://localhost:3000

# ── SEGURIDAD ────────────────────────────────────────────────
SUPER_ACCESS_KEY=cambia-en-produccion   # Shield de super admin
CRON_SECRET=cambia-en-produccion        # Vercel Crons

# ── THEFORK (integración futura) ─────────────────────────────
THEFORK_API_KEY=                        # Pendiente

# ── NVIDIA NIM (LLM primario) ─────────────────────────────────
NVIDIA_API_KEY=nvapi-...            # console.ngc.nvidia.com
NVIDIA_BRAIN_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# ── AZURE SPEECH (voice profiles) ────────────────────────────
AZURE_SPEECH_KEY=                   # Pendiente — portal.azure.com
AZURE_SPEECH_REGION=westeurope

# ── TELEGRAM ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                 # t.me/BotFather
TELEGRAM_CHAT_ID=                   # ID del chat del operador
TELEGRAM_WEBHOOK_SECRET=            # Secreto para validar callbacks

# ── RESEND (email externo) ────────────────────────────────────
RESEND_API_KEY=re_...               # resend.com

# ── APIFY (sourcing Google Places para prospeccion catering/eventos) ──
APIFY_TOKEN=                        # apify.com → Settings → Integrations → API token

# ── CLOUDINARY (imágenes Instagram/eventos) ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── INSTAGRAM ────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=             # Meta Developer Portal
INSTAGRAM_USER_ID=

# ── WHATSAPP ─────────────────────────────────────────────────
WHATSAPP_API_TOKEN=                 # Meta Developer Portal
WHATSAPP_PHONE_ID=

# ── GITHUB (blog/agente arquitecto) ──────────────────────────
GH_PAT=ghp_...                      # github.com/settings/tokens (scope: repo)
# NOTA: usar siempre GH_PAT, nunca GITHUB_TOKEN

# ── GOOGLE (backup Drive / blog SEO) ─────────────────────────
GOOGLE_CLIENT_ID=                   # console.cloud.google.com
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=         # Obtenido via /api/backup/drive-auth
GOOGLE_DRIVE_FOLDER_ID=
# NOTA: usar siempre GOOGLE_CLIENT_ID, nunca GOOGLE_OAUTH_CLIENT_ID

# ── VERCEL API (crons internos) ───────────────────────────────
VERCEL_TOKEN=                       # vercel.com/account/tokens
VERCEL_TOKEN_INTERNAL=              # Alias de VERCEL_TOKEN para google-oauth-callback
VERCEL_TEAM_ID=team_f4gPpt6dPuNcd5YyMt3q27uf
VERCEL_PROJECT_ID=prj_A0xZtqWcH6dtNEmlRiOwgj52GTRo

# ── OPENAI (fallback ASR si Groq falla) ──────────────────────
OPENAI_API_KEY=sk-...               # Fallback en lib/ear.ts si Groq no disponible

# ── STRIPE (adicionales) ─────────────────────────────────────
STRIPE_WEBHOOK_SECRET_STOREFRONT=whsec_...   # Webhook storefront
STRIPE_WEBHOOK_SECRET_PROPINAS=whsec_...     # Webhook propinas

# ── MISC ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000     # Prod: https://www.iarest.es
# NOTA: usar siempre NEXT_PUBLIC_APP_URL, nunca NEXT_PUBLIC_URL
EAR_PROVIDER=groq                            # 'groq' (default) | 'openai'
DRIVE_SA_EMAIL=ia-rest-sa@ia-rest-drive.iam.gserviceaccount.com
DRIVE_SA_KEY=                                # Private key del SA (sin saltos de línea)
