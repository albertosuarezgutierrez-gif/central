# Tolerancia de peer deps equivalente a npm --legacy-peer-deps (evita que pnpm
# falle por conflictos de peers preexistentes en las 3 verticales).
strict-peer-dependencies=false
auto-install-peers=true
# Resiliencia de red en el registro (el build de Vercel re-descarga al migrar de
# npm a pnpm y puede pegarse errores transitorios ERR_INVALID_THIS / fetch).
fetch-retries=6
fetch-retry-mintimeout=2000
fetch-retry-maxtimeout=60000
fetch-timeout=120000
