# Tolerancia de peer deps equivalente a npm --legacy-peer-deps (evita que pnpm
# falle por conflictos de peers preexistentes en las 3 verticales).
strict-peer-dependencies=false
auto-install-peers=true
# Resiliencia de red en el registro (el build de Vercel re-descarga al migrar de
# npm a pnpm y puede pegarse errores transitorios ERR_INVALID_THIS / fetch del
# registro npm). ia-rest tiene el set de deps más grande y store fría → agota
# antes la ventana de reintentos; ampliamos retries para superar un blip del
# registro que dure varios minutos (CI y los previews de sivra/ialimp pasan con
# el mismo install → el fallo es del registro, no del repo).
fetch-retries=10
fetch-retry-mintimeout=2000
fetch-retry-maxtimeout=60000
fetch-timeout=120000
